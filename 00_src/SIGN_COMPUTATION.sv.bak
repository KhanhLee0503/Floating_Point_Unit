module SIGN_COMPUTATION
    input logic I_ADD_SUB,
    input logic I_SIGN_A,
    input logic I_SIGN_B,

    input logic I_EXPONENT_GT,
    input logic I_EXPONENT_EQ,
    input logic I_MANTISSA_GT,
    input logic I_MANTISSA_EQ,

    output logic O_SIGN_OUT
);

logic eff_sign_b; 
logic a;
logic b;
logic c;
logic d;
logic e;

assign eff_sign_b = I_SIGN_B ^ I_ADD_SUB;
assign a          = I_SIGN_A ^ eff_sign_b;
assign b          = (c) ? I_SIGN_A : eff_sign_b;
assign c          = I_EXPONENT_GT | (I_MANTISSA_GT & I_EXPONENT_EQ);
assign d          = (a) ? I_SIGN_A : b;
assign O_SIGN_OUT = (I_EXPONENT_EQ & I_MANTISSA_EQ & a) ? 1'b0 : d;

endmodule : SIGN_COMPUTATION